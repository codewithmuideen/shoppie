# ─────────────────────────────────────────────────────────────────────────────
# 0528creatives inc. — environment template
#
# 1) Copy this file to `.env` (same folder)
# 2) Fill in the values from your Supabase dashboard → Project Settings → API
# 3) Restart the dev server. On Vercel: Project → Settings → Environment
#    Variables → add the same keys, then redeploy.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL — looks like  https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (public) key — safe to expose in the browser bundle.
# DO NOT use the service_role key here.
VITE_SUPABASE_ANON_KEY=

# Admin password for the /admin panel.
# Override the default `maison2026`. Min. 12 chars recommended.
VITE_ADMIN_PASSWORD=
